#!/bin/bash
# ctq — claude-token-queue 메인 명령 디스패처
QDIR="$HOME/.claude-queue"
cmd="$1"; [ $# -gt 0 ] && shift

case "$cmd" in
  run)   exec "$QDIR/cq.sh" "$@" ;;
  add)   exec "$QDIR/add.sh" "$@" ;;
  at)    exec "$QDIR/schedule.sh" "$@" ;;
  drain) exec "$QDIR/runner.sh" ;;
  status)
    echo "== 정식 큐 (queue.jsonl, 워처/MCP가 쓰는 큐) =="
    if [ -s "$QDIR/queue.jsonl" ]; then
      python3 - "$QDIR/queue.jsonl" <<'PY'
import json,sys
for i,l in enumerate([x for x in open(sys.argv[1]) if x.strip()],1):
    try: r=json.loads(l)
    except: continue
    # 표시는 한 줄로: 개행 제거 + 90자에서 자름(…). 전체 원문은 queue.jsonl에 온전히 저장돼 있음.
    p=" ".join((r.get('prompt') or '').split())
    p=(p[:90]+"…") if len(p)>90 else p
    print(f"  {i}. [{r.get('source','?')}] reset={r.get('reset')} resume={r.get('resume')} session={(r.get('session_id') or '')[:8]}")
    print(f"      {p}")
PY
    else echo "  (없음)"; fi
    echo "== 레거시 큐 (jobs.txt) =="
    if [ -s "$QDIR/jobs.txt" ]; then nl -ba "$QDIR/jobs.txt"; else echo "  (없음)"; fi
    echo "== 감지 데몬 (워처) =="
    launchctl list 2>/dev/null | grep -q claude-token-queue.watcher && echo "  구동 중 ✅" || echo "  꺼짐 ❌ (install_watcher 필요)"
    echo "== 재실행 예약 =="
    launchctl list 2>/dev/null | grep claudequeue >/dev/null && echo "  로드됨" || echo "  (로드 안 됨)"
    plist="$HOME/Library/LaunchAgents/com.user.claudequeue.plist"
    if [ -f "$plist" ]; then
      h=$(/usr/libexec/PlistBuddy -c "Print :StartCalendarInterval:Hour" "$plist" 2>/dev/null)
      m=$(/usr/libexec/PlistBuddy -c "Print :StartCalendarInterval:Minute" "$plist" 2>/dev/null)
      [ -n "$h" ] && printf "  다음 실행 예정: %02d:%02d\n" "$h" "${m:-0}"
    fi
    ;;
  log)   tail -n 40 "$QDIR/runner.log" 2>/dev/null || echo "(로그 없음)" ;;
  cancel)
    launchctl unload "$HOME/Library/LaunchAgents/com.user.claudequeue.plist" 2>/dev/null
    echo "예약 취소됨 (큐는 유지)"
    ;;
  clear)
    # 정식 큐(queue.jsonl)와 레거시 큐(jobs.txt) 둘 다 비우고, 재실행 예약도 해제
    : > "$QDIR/queue.jsonl"
    : > "$QDIR/jobs.txt"
    launchctl unload "$HOME/Library/LaunchAgents/com.user.claudequeue.plist" 2>/dev/null
    rm -f "$HOME/Library/LaunchAgents/com.user.claudequeue.plist"
    echo "큐 비움 (queue.jsonl + jobs.txt) + 재실행 예약 해제"
    echo "참고: 감지 데몬이 켜져 있으면 '아직 멈춘(이후 대화 없는)' 한도 건은 다시 잡힐 수 있음"
    ;;
  *)
    cat <<'USAGE'
claude-token-queue — 토큰 한도로 막힌 작업을 리셋 시각에 자동 재실행

사용법: ctq <명령>
  ctq run "프롬프트"   claude 실행. 한도면 자동 큐 등록 + 리셋 시각 자동 예약
  ctq add "프롬프트"   큐에만 수동 등록 (대화형에서 막힌 거 옮길 때)
  ctq at 14:30         재실행 시각 예약  (+30m, +2h 도 가능)
  ctq status           큐/예약 상태 확인
  ctq log              실행 로그 (최근 40줄)
  ctq drain            지금 즉시 큐 실행
  ctq cancel           예약 취소
  ctq clear            큐 비우기
USAGE
    ;;
esac
